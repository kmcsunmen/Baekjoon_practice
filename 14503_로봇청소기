#include <stdio.h>

int N, M, r, c, d;
int cnt = 0;
int map[50][50];

void clean(int x, int y, int direction) {
	// 1. 현재 칸이 청소가 안 되어 있다면, 청소한다
	if (map[x][y] == 0) {
		cnt++;
		map[x][y] = 2;
	}
	
	// 2. 현재 칸 주변 4칸 중 청소되지 않은 빈 칸이 없다면
	if (map[x - 1][y]!=0 && map[x][y + 1]!=0 && map[x + 1][y]!=0 && map[x][y - 1]!=0) {
		// 2-1. 방향 유지한채 한 칸 후진
		switch (direction) {
		case 0:
			if (map[x + 1][y] != 1) clean(x + 1, y, 0);
			break;
		case 1:
			if (map[x][y - 1] != 1) clean(x, y - 1, 1);
			break;
		case 2:
			if (map[x - 1][y] != 1) clean(x - 1, y, 2);
			break;
		case 3:
			if (map[x][y + 1] != 1) clean(x, y + 1, 3);
			break;
		}
		// 후진할 수 없다면 종료
		return;
	}
	// 3. 현재 칸 주변 4칸 중 청소되지 않은 빈 칸이 있다면
	else {
		// 반시계 90도 회전
		switch (direction) {
		case 0:
			if (map[x][y - 1] == 0) clean(x, y-1, 3);
			else clean(x, y, 3);
			break;
		case 1:
			if (map[x - 1][y] == 0) clean(x-1, y, 0);
			else clean(x, y, 0);
			break;
		case 2:
			if (map[x][y + 1] == 0) clean(x, y+1, 1);
			else clean(x, y, 1);
			break;
		case 3:
			if (map[x + 1][y] == 0) clean(x+1, y, 2);
			else clean(x, y, 2);
			break;
		}
	}
}

int main() {
	scanf("%d %d", &N, &M);
	scanf("%d %d %d", &r, &c, &d);
	for (int i = 0; i < N; i++) {
		for (int j = 0; j < M; j++) {
			scanf("%d", &map[i][j]);
		}
	}
	clean(r, c, d);
	printf("%d\n", cnt);
	return 0;
}
