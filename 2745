#include <stdio.h>
#include <stdlib.h>

int E2D(char c) {
    if (c >= '0' && c <= '9') return c - '0';
    else return c - 'A' + 10;
}

int main() {
    char N[40];
    int B, sum = 0;
    scanf("%s %d", N, &B);
    int len = strlen(N);
    for (int i = 0; i < len; i++) {
        sum = sum * B + E2D(N[i]);
    }
    printf("%d\n", sum);
    return 0;
}
